#!/usr/bin/env bash
# pomoctl — deprecated. The Pomo CLI converged on a single command: `pomo`
# (npm package: @arach/pomo, source in apps/cli). This shim just forwards to it
# so existing `pomoctl …` muscle memory and symlinks keep working.
if command -v pomo >/dev/null 2>&1; then
  exec pomo "$@"
fi
cat >&2 <<'EOF'
pomoctl has moved to `pomo`.
  • from this repo:  apps/macos/scripts/install-cli.sh    (symlinks `pomo` onto your PATH)
  • or anywhere:     npm install -g @arach/pomo            (or run: npx @arach/pomo <command>)
EOF
exit 127
